<odoo>
    <data>
        <record id="wizard_test_printer_form" model="ir.ui.view">
            <field name="name">wizard_test_printer_form</field>
            <field name="model">wizard.test.printer</field>
            <field name="arch" type="xml">
                <form string="">
                        <!-- <div class="oe_title">
                            <span>Printer Name</span>
                            <h1><field name="name"/></h1>
                        </div> -->
                        <group>
                            <group>
                                <field name="idVendor" readonly="True" />
                                <field name="idProduct" readonly="True" />
                                <field name="printerType" readonly="True" />
                                <field name="use_editer" widget="boolean_toggle" />
                            </group>
                            <group>
                                <field name="noOfPrint" required="True" />
                            </group>
                            <notebook>
                                <page string="Content">
                                    <field name="content" invisible="use_editer == True" />
                                    <field name="editor"  placeholder="Write here..." invisible="use_editer == False" />
                                </page>
                            </notebook>
                        </group>
                        <footer>
                            <button string="Print" class="btn-primary" type="object" name="test_printer"/>
                            <button string="Cancel" class="btn-secondary" special="cancel"/>
                        </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
