    <record id="view_attachment_automation_list" model="ir.ui.view">
        <field name="name">attachment.automation.list</field>
        <field name="model">attachment.automation</field>
        <field name="arch" type="xml">
            <list string="Attachment Automation">
                <field name="model_ids" />
                <field name="print_type" />
                <field name="printer_ids" />
            </list>
        </field>
    </record>

    <record id="view_attachment_automation_form" model="ir.ui.view">
        <field name="name">attachment.automation.form</field>
        <field name="model">attachment.automation</field>
        <field name="arch" type="xml">
            <form string="Attachment Automation">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- ACTIVE -->
                        <button name="toggle_is_active"
                            type="object"
                            icon="fa-power-off"
                            invisible="not is_active">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <span class="text-success">Active</span>
                                </span>
                            </div>
                        </button>

                        <!-- INACTIVE -->
                        <button name="toggle_is_active"
                            type="object"
                            icon="fa-power-off"
                            invisible="is_active">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <span class="text-danger">Inactive</span>
                                </span>
                            </div>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="model_ids" widget="many2many_tags" />
                            <field name="print_type" widget="radio" />
                        </group>
                        <group>
                            <field name="printer_ids" widget="many2many_tags" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_attachment_automation" model="ir.actions.act_window">
        <field name="name">Attachment Automation</field>
        <field name="res_model">attachment.automation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_attachment_automation"
        name="Attachment Automation"
        action="action_attachment_automation"
        parent="direct_printer_Automation"
        sequence="2"
    />


</odoo>