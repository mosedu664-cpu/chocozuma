<odoo>
    <data>
        <record id="view_print_job_source_form" model="ir.ui.view">
            <field name="name">print.job.source.form</field>
            <field name="model">print.job.source</field>
            <field name="arch" type="xml">
                <form string="Print Job Source">
                    <sheet>
                        <group>
                            <group>
                                <field name="print_job_id" readonly='True' />
                                <field name="print_id" readonly='True'/>
                                <field name="source_ref_char" invisible='source_ref' readonly='True'/>
                                <field name="source_ref" readonly='True' invisible='not source_ref' />
                            </group>

                            <group>
                                <field name="print_job_for" readonly='True' />
                                <field name="content_ref" readonly='True' />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_print_job_source_tree" model="ir.ui.view">
            <field name="name">print.job.source.tree</field>
            <field name="model">print.job.source</field>
            <field name="arch" type="xml">
                <list create="false" delete="false">
                    <field name="print_id" />
                    <field name="content_ref" />
                    <field name="print_job_for" />
                    <field name="source_ref" />
                </list>
            </field>
        </record>


        <record id="action_print_job_source" model="ir.actions.act_window">
            <field name="name">Print Job Source</field>
            <field name="res_model">print.job.source</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>