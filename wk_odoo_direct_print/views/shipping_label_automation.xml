<odoo>
    <record id="view_shipping_label_automation_list" model="ir.ui.view">
        <field name="name">shipping.label.automation.list</field>
        <field name="model">shipping.label.automation</field>
        <field name="arch" type="xml">
            <list string="Shipping Label Automation">
                <field name="name" />
                <field name="carrier_ids" />
                <field name="print_label" />
                <field name="print_documents" />
                <field name="is_active" />
            </list>
        </field>
    </record>

    <record id="view_shipping_label_automation_form" model="ir.ui.view">
        <field name="name">shipping.label.automation.form</field>
        <field name="model">shipping.label.automation</field>
        <field name="arch" type="xml">
            <form string="Shipping Label Automation">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                            name="toggle_is_active"
                            icon="fa-power-off"
                            invisible="not is_active">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <span class="text-success">Active</span>
                                </span>
                            </div>
                        </button>

                        <button type="object"
                            name="toggle_is_active"
                            icon="fa-power-off"
                            invisible="is_active">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <span class="text-danger">Inactive</span>
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <span>Name</span>
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="carrier_ids" widget="many2many_tags" />
                            <field name="picking_type_ids" widget="many2many_tags" />
                            <field name="printer_ids" widget="many2many_tags" />
                        </group>

                        <group>

                            <group>
                                <field name="print_label" />
                                <field name="print_documents" />
                            </group>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>
    <record id="action_shipping_label_automation" model="ir.actions.act_window">
        <field name="name">Shipping Label Automation</field>
        <field name="res_model">shipping.label.automation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_shipping_label_automation"
        name="Shipping Label Automation"
        parent="direct_printer_Automation"
        sequence="3"
        action="action_shipping_label_automation" />

</odoo>