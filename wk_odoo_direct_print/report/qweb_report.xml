    <data noupdate="1">
        <!-- QWeb Reports -->
        <record id="sale_order_direct_print" model="ir.actions.report">
            <field name="name">Order List (ESCPOS)</field>
            <field name="model">sale.order</field>
            <field name="report_type">qweb-text</field>
            <field name="report_name">wk_odoo_direct_print.escpos_receipt_sale_order</field>
            <field name="report_file">wk_odoo_direct_print.escpos_receipt_sale_order</field>
            <field name="print_report_name">(object.name)</field>
            <field name="attachment" />
            <field name="binding_model_id" ref="sale.model_sale_order" />
            <field name="binding_type">report</field>
            <field name="printerType">ESCPOS</field>
        </record>

        <record id="account_invoices_direct_print" model="ir.actions.report">
            <field name="name">Invoice (ESCPOS)</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-text</field>
            <field name="report_name">wk_odoo_direct_print.escpos_receipt_account_invoice</field>
            <field name="report_file">wk_odoo_direct_print.escpos_receipt_account_invoice</field>
            <field name="print_report_name">(object.name)</field>
            <field name="attachment" />
            <field name="binding_model_id" ref="account.model_account_move" />
            <field name="binding_type">report</field>
            <field name="printerType">ESCPOS</field>
        </record>

    </data>
</odoo>