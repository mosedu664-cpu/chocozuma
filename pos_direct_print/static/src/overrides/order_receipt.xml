<templates id="template" xml:space="preserve">

    <t t-name="pos_direct_print.posOrCode">
        <div class="pos-receipt my-0 py-0">
            <div t-if="props.data.pos_qr_code">
                <div class="pos-receipt-order-data mb-1">
                    Scan me to request an invoice for your purchase.
                </div>
                <div t-if="['qr_code', 'qr_code_and_url'].includes(props.data.headerData.company.point_of_sale_ticket_portal_url_display_mode) and props.data.pos_qr_code" class="mb-2">
                    <img id="posqrcode" t-att-src="props.data.pos_qr_code" class="pos-receipt-logo"/>
                </div>
            </div>
        </div>
    </t>    

    <t t-name="pos_direct_print.OrderReceiptFooter">
        <receipt align='center' width='40' value-thousands-separator='' indent="1">
            <div font='a'>
                <div class="after-footer">
                    <t t-foreach="props.data.paymentlines" t-as="line" t-key="line_index">
                        <t t-if="line.ticket">
                            <br />
                            <div class="pos-payment-terminal-receipt">
                                <pre t-esc="line.ticket" />
                            </div>
                        </t>
                    </t>
                </div>
                <t t-if="props.data.shippingDate">
                    <br/>
                    <div class="pos-receipt-order-data">
                        Expected delivery:
                        <div><t t-esc="props.data.shippingDate" /></div>
                    </div>
                </t>

                <div t-if="props.data.pos_qr_code">
                    <br/>
                    <div class="pos-receipt-order-data mb-2">
                        Need an invoice for your purchase ?
                    </div>
                </div>

                <div t-if="props.data.pos_qr_code">
                    <div class="unique-code pos-receipt-order-data">
                        Unique Code: <t t-esc="props.data.ticket_code"/>
                    </div>
                </div>

                <div t-if="['url', 'qr_code_and_url'].includes(props.data.headerData.company.point_of_sale_ticket_portal_url_display_mode) and props.data.pos_qr_code">
                    <div class="portal-url pos-receipt-order-data" t-attf-class="{{ props.data.ticket_portal_url_display_mode === 'qr_code_and_url' ? 'mt-3' : '' }}">
                        <t t-set="portal_url" t-attf-value="#{props.data.base_url}/pos/ticket"/>
                        Portal URL: <t t-esc="portal_url"/>
                    </div>
                </div>
                <!-- Start Pos Loyality Start -->
                <t t-if="props.data.partner">
                    <br/>
                    <div>Customer <span t-esc='props.data.partner.name' class='pos-receipt-right-align'/></div>
                </t>
                <!-- Start Pos Loyality End -->
                <t t-if="props.data.footer">
                    <h5 font="b">
                        <pre t-esc="props.data.footer" />
                    </h5>
                    <!-- <h5 t-esc='props.data.footer' /> -->
                    <br/>
                </t>
                <div>Powered by Odoo</div>
                <div><t t-esc='props.data.name' /></div>
                <div><t t-esc='props.data.date' /></div>
            </div>
        </receipt>
    </t>

    <t t-name="XmlReceiptWrappedProductNameLines">
        <t t-foreach="line.name_wrapped.slice(1)" t-as="wrapped_line" t-key="wrapped_line_index">
            <line bold='on'>
                <left><t t-esc="wrapped_line"/></left>
            </line>
        </t>
    </t>
    <t t-name="XmlReceiptWrappedUnitLines">
        <t t-foreach="line.line_unit_price_wrapped.slice(1)" t-as="wrapped_line" t-key="wrapped_line_index">
            <line line-ratio='0.8'>
                <left><pre> </pre><t t-esc="wrapped_line"/></left>
            </line>
        </t>
    </t>
    

    <t t-name="pos_direct_print.OrderReceipt">
        <receipt align='center' width='40' value-thousands-separator='' >
            <!-- <br/> -->
            <br/>
            <h4><t t-esc='props.data.headerData.company.name' /></h4>
            <br/>
            <div font='a'>
                <t t-if='props.data.headerData.company.phone'>
                    <h5>Tel:<t t-esc='props.data.headerData.company.phone' /></h5>
                </t>
                <t t-if='props.data.headerData.company.vat'>
                    <h5>VAT:<t t-esc='props.data.headerData.company.vat' /></h5>
                </t>
                <t t-if='props.data.headerData.company.email'>
                    <h5><t t-esc='props.data.headerData.company.email' /></h5>
                </t>
                <t t-if='props.data.headerData.company.website'>
                    <h5><t t-esc='props.data.headerData.company.website' /></h5>
                </t>
                <t t-if='props.data.headerData.header'>
                    <h5><t t-raw='props.data.headerData.header' /></h5>
                </t>
                <t t-if='props.data.cashier'>
                    <div class='cashier'>
                        <div>--------------------------------</div>
                        <h5 t-if="props.data.waiter_name">Waiter: <t t-esc="props.data.waiter_name"/></h5>
                        <h5 t-else="">Served by 
                            <!--  employee: ba_pos_restaurant_extended (third party module)-->
                            <t t-if="props.data.employee" t-esc='props.data.employee[1]' />
                            <t t-else="" t-esc='props.data.cashier' />
                        </h5>
                    </div>
                </t>
                <t t-if='props.data.headerData.table'>
                    <h5>at table: <t t-esc='props.data.headerData.table' /></h5>
                </t>
                <t t-if='props.data.headerData.customer_count'>
                    <h5>Guests: <t t-esc='props.data.headerData.customer_count' /></h5>
                </t>
                <t t-if='props.data.headerData.trackingNumber'>
                    <div size='double'><t t-esc='props.data.headerData.trackingNumber' /></div>
                </t>
            </div>
            <br /><br />
            <div class='orderlines' line-ratio='0.6'>
                <t t-foreach='props.data.orderlines' t-as='line' t-key="line_index">
                    <t t-set='simple' t-value='line.discount === "0" and line.unit === "Units" and line.qty === "1.00"' />
                    <line bold='on'>
                        <left><t t-esc='line.name_wrapped[0]' /></left>
                        <right><t t-esc='line.price' /></right>
                    </line>
                    <t t-call="XmlReceiptWrappedProductNameLines"/>
                    <line indent='1' line-ratio='0.8'>
                        <left>
                            <t t-esc='line.line_unit_price_wrapped[0]' />
                        </left>
                        <right>

                        </right>
                    </line>
                    <t t-call="XmlReceiptWrappedUnitLines"/>
                    <t t-if='!line.discount !== "0" and line.discount'>
                        <line indent='1' bold="on"><left>Discount: <t t-esc='line.discount' />%</left></line>
                    </t>
                    <t t-if="line.customerNote">
                        <line indent='1' line-ratio='1' font="b">
                            <left>
                                <t t-esc="line.customerNote"/>
                            </left>
                            <right>
                            </right>
                        </line>
                    </t>
                    <t t-if="line.pack_lot_lines">
                        <t t-foreach="line.pack_lot_lines" t-as="lot" t-key="lot_index">
                            <line>
                                <left>
                                    <t t-if="lot.order_line.product.tracking == 'lot'">
                                        Lot Number <t t-esc="lot.lot_name"/>
                                    </t>
                                    <t t-else="">
                                        SN <t t-esc="lot.lot_name"/>
                                    </t>
                                </left>
                                <right></right>
                            </line>
                        </t>
                    </t>
                    <br/>
                </t>
            </div>

            <!-- Total -->
            <line><right>--------</right></line>
            <div>
                <line font='a' size='double-height double-width' bold='on'>
                    <left>        TOTAL</left>
                    <right><t t-esc='props.data.formatedAmountTotal'/></right>
                </line>
            </div>
            <br/>
            <!-- Payment Lines -->
            <t t-foreach='props.data.paymentlines' t-as='line' t-key="line_index">
                <line>
                    <left bold='on'><t t-esc='line.name'/></left>
                    <right><t t-esc='line.formatedAmount'/></right>
                </line>
                <br/>
            </t>
            <t t-if='props.data.show_change'>
                <line>
                    <left>CHANGE</left>
                    <right><t t-esc='props.data.formatedChange'/></right>
                </line>
                <br /><br />
            </t>
            <!-- Extra Payment Info -->
            <t t-if='props.data.total_discount'>
                <line>
                    <left>Discounts</left>
                    <right><t t-esc='props.data.formatedTotalDiscount'/></right>
                </line>
                <br /><br />
            </t>

            <t t-if='props.data.tax_details and props.data.tax_details.length > 0'>
                <line bold='on'>
                    <left>Tax</left>
                    <right>Amount</right>
                </line>
                <t t-foreach='props.data.tax_details' t-as='tax' t-key="tax_index">
                    <line>
                        <left><t t-esc='tax.tax.name' /></left>
                        <right><t t-esc='tax.formatedAmount' /></right>
                    </line>
                </t>
                <line>
                    <left>Total Taxes</left>
                    <right><t t-esc='props.data.formatedTotalTaxs'/></right>
                </line>
            </t>      
        </receipt>
    </t>
</templates>
