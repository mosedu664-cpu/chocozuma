         CONFIGURATION (Admin only)
    ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_grant_config"
              name="Configuration"
              parent="menu_grant_root"
              sequence="100"
              groups="goodsports_grant_management.group_grant_admin"/>

    <menuitem id="menu_grant_focus_areas"
              name="Focus Areas"
              parent="menu_grant_config"
              sequence="10"
