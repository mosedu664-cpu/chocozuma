              name="Pipeline Stages"
              parent="menu_grant_config"
              sequence="20"
              action="action_grant_opportunity_stage"
              groups="goodsports_grant_management.group_grant_admin"/>

    <!-- ═══════════════════════════════════════════════════════════════
         FORM 990 MENU (added to Compliance section)
    ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_form_990"
              name="Form 990 Returns"
              parent="menu_grant_compliance"
              action="action_form_990"
              sequence="50"/>

    <!-- ═══════════════════════════════════════════════════════════════
         FORM 990 MENU (added in v2)
    ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_form990_root"
              name="Form 990"
              parent="menu_grant_root"
              sequence="45"/>

    <menuitem id="menu_form990_list"
              name="All Returns"
              parent="menu_form990_root"
              action="goodsports_grant_management.action_form_990"
              sequence="10"/>

    <menuitem id="menu_form990_new"
              name="New Return"
              parent="menu_form990_root"
              action="goodsports_grant_management.action_form_990"
              sequence="20"/>

