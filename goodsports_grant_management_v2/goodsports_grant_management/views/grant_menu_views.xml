<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         ROOT MENU
    ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_grant_root"
              name="Grant Management"
              sequence="50"
              web_icon="goodsports_grant_management,static/description/icon.png"
              groups="goodsports_grant_management.group_grant_user"/>

    <!-- ═══════════════════════════════════════════════════════════════
         DASHBOARD
    ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_grant_dashboard"
