    ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_grant_pipeline"
              name="Pipeline"
              parent="menu_grant_root"
              sequence="10"/>

    <menuitem id="menu_grant_opportunity"
              name="Opportunities"
              parent="menu_grant_pipeline"
              action="action_grant_opportunity"
              sequence="10"/>

    <menuitem id="menu_grant_funder"
              name="Funders"
              parent="menu_grant_pipeline"
              action="action_grant_funder"
              sequence="20"/>

    <!-- ═══════════════════════════════════════════════════════════════
         ACTIVE GRANTS
    ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_grant_active"
              name="My Grants"
              parent="menu_grant_root"
              sequence="20"/>

