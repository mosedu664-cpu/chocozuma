<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Grant Status Report (printable summary per grant) ─── -->
    <record id="action_report_grant_status" model="ir.actions.report">
        <field name="name">Grant Status Report</field>
        <field name="model">grant.grant</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">goodsports_grant_management.report_grant_status_document</field>
        <field name="report_file">goodsports_grant_management.report_grant_status_document</field>
        <field name="print_report_name">'Grant Status - ' + object.reference</field>
        <field name="binding_model_id" ref="model_grant_grant"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_grant_status_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="grant">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="row mb-4">
                            <div class="col-8">
                                <h2 class="text-primary">Grant Status Report</h2>
                                <h3><t t-esc="grant.name"/></h3>
                                <p class="text-muted">Reference: <t t-esc="grant.reference"/></p>
                            </div>
                            <div class="col-4 text-end">
                                <div class="badge fs-6"
                                     t-att-class="'bg-success' if grant.state == 'active' else 'bg-secondary'">
                                    <t t-esc="dict(grant._fields['state'].selection).get(grant.state)"/>
                                </div>
                                <p class="text-muted mt-2">Generated: <t t-esc="env.context_today().strftime('%B %d, %Y')"/></p>
                            </div>
                        </div>

                        <hr/>

                        <!-- Grant Overview -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h4>Grant Information</h4>
                                <table class="table table-sm table-borderless">
                                    <tr><td class="text-muted fw-bold" style="width:45%">Funder:</td>
                                        <td><t t-esc="grant.funder_id.name"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Funder Reference:</td>
                                        <td><t t-esc="grant.funder_reference or '—'"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Grant Type:</td>
                                        <td><t t-esc="dict(grant._fields['grant_type'].selection).get(grant.grant_type)"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Program Manager:</td>
                                        <td><t t-esc="grant.program_manager_id.name if grant.program_manager_id else '—'"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Focus Areas:</td>
                                        <td><t t-esc="', '.join(grant.focus_area_ids.mapped('name')) or '—'"/></td></tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <h4>Key Dates</h4>
                                <table class="table table-sm table-borderless">
                                    <tr><td class="text-muted fw-bold" style="width:45%">Award Date:</td>
                                        <td><t t-esc="grant.award_date or '—'"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Project Start:</td>
                                        <td><t t-esc="grant.project_start_date"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Project End:</td>
                                        <td><t t-esc="grant.project_end_date"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Next Report Due:</td>
                                        <td><t t-esc="grant.next_report_due or '—'"/></td></tr>
                                    <tr><td class="text-muted fw-bold">Days Remaining:</td>
                                        <td>
                                            <span t-att-class="'text-danger fw-bold' if grant.is_overdue else ''">
                                                <t t-esc="grant.days_remaining"/>
                                            </span>
                                        </td></tr>
                                </table>
                            </div>
                        </div>

                        <!-- Financial Summary -->
                        <h4 class="mt-3">Financial Summary</h4>
                        <div class="row mb-4">
                            <div class="col-3">
                                <div class="card border text-center p-3">
                                    <div class="fs-5 fw-bold text-primary">
                                        <t t-esc="'{:,.2f}'.format(grant.awarded_amount)"/>
                                        <small class="d-block text-muted fs-6">
                                            <t t-esc="grant.currency_id.symbol"/>
                                        </small>
                                    </div>
                                    <div class="text-muted small">Awarded</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="card border text-center p-3">
                                    <div class="fs-5 fw-bold text-danger">
                                        <t t-esc="'{:,.2f}'.format(grant.total_expenses)"/>
                                    </div>
                                    <div class="text-muted small">Total Spent</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="card border text-center p-3">
                                    <div class="fs-5 fw-bold text-success">
                                        <t t-esc="'{:,.2f}'.format(grant.remaining_budget)"/>
                                    </div>
                                    <div class="text-muted small">Remaining</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="card border text-center p-3">
                                    <div class="fs-5 fw-bold">
                                        <t t-esc="'{:.1f}'.format(grant.budget_utilization)"/>%
                                    </div>
                                    <div class="text-muted small">Utilization</div>
                                </div>
                            </div>
                        </div>

                        <!-- Budget Lines -->
                        <t t-if="grant.budget_line_ids">
                            <h4>Budget Breakdown</h4>
                            <table class="table table-sm table-bordered mb-4">
                                <thead class="table-light">
                                    <tr>
                                        <th>Category</th>
                                        <th>Expense Type</th>
                                        <th class="text-end">Budgeted</th>
                                        <th class="text-end">Actual</th>
                                        <th class="text-end">Variance</th>
                                        <th class="text-end">Utilization</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="grant.budget_line_ids" t-as="line">
                                        <tr t-att-class="'table-danger' if line.utilization_pct > 100 else ''">
                                            <td><t t-esc="line.name"/></td>
                                            <td><t t-esc="dict(line._fields['expense_category'].selection).get(line.expense_category)"/></td>
                                            <td class="text-end"><t t-esc="'{:,.2f}'.format(line.budgeted_amount)"/></td>
                                            <td class="text-end"><t t-esc="'{:,.2f}'.format(line.actual_amount)"/></td>
                                            <td class="text-end"
                                                t-att-class="'text-danger' if line.variance &lt; 0 else 'text-success'">
                                                <t t-esc="'{:,.2f}'.format(line.variance)"/>
                                            </td>
                                            <td class="text-end"><t t-esc="'{:.1f}'.format(line.utilization_pct)"/>%</td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot class="table-light fw-bold">
                                    <tr>
                                        <td colspan="2">Total</td>
                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(sum(grant.budget_line_ids.mapped('budgeted_amount')))"/></td>
                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(grant.total_expenses)"/></td>
                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(grant.remaining_budget)"/></td>
                                        <td class="text-end"><t t-esc="'{:.1f}'.format(grant.budget_utilization)"/>%</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- Milestones -->
                        <t t-if="grant.milestone_ids">
                            <h4>Milestones &amp; Deliverables</h4>
                            <table class="table table-sm table-bordered mb-4">
                                <thead class="table-light">
                                    <tr>
                                        <th>Milestone</th>
                                        <th>Type</th>
                                        <th>Due Date</th>
                                        <th>Status</th>
                                        <th>Target</th>
                                        <th>Achieved</th>
                                        <th class="text-end">Achievement</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="grant.milestone_ids" t-as="ms">
                                        <tr t-att-class="'table-success' if ms.state == 'done' else ('table-danger' if ms.is_overdue else '')">
                                            <td><t t-esc="ms.name"/></td>
                                            <td><t t-esc="dict(ms._fields['milestone_type'].selection).get(ms.milestone_type)"/></td>
                                            <td><t t-esc="ms.due_date"/></td>
                                            <td><t t-esc="dict(ms._fields['state'].selection).get(ms.state)"/></td>
                                            <td><t t-esc="'{:.0f} {}'.format(ms.target_quantity, ms.unit_of_measure or '')"/></td>
                                            <td><t t-esc="'{:.0f} {}'.format(ms.actual_quantity, ms.unit_of_measure or '')"/></td>
                                            <td class="text-end"><t t-esc="'{:.1f}'.format(ms.achievement_pct)"/>%</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Compliance Notes -->
                        <t t-if="grant.reporting_requirements or grant.restrictions">
                            <h4>Compliance Notes</h4>
                            <t t-if="grant.reporting_requirements">
                                <p class="fw-bold mb-1">Reporting Requirements:</p>
                                <p><t t-esc="grant.reporting_requirements"/></p>
                            </t>
                            <t t-if="grant.restrictions">
                                <p class="fw-bold mb-1">Restrictions &amp; Conditions:</p>
                                <p><t t-esc="grant.restrictions"/></p>
                            </t>
                        </t>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
