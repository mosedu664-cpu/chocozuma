<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_waste" model="ir.ui.view">
        <field name="name">res.company.form.inherit.waste</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']//group[2]" position="inside">
                <field name="waste_location_id" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
