<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Waste Log Views ==================== -->

    <!-- List View -->
    <record id="waste_log_view_list" model="ir.ui.view">
        <field name="name">waste.log.list</field>
        <field name="model">waste.log</field>
        <field name="arch" type="xml">
            <list string="Waste Logs" decoration-warning="state == 'draft'" decoration-success="state == 'confirmed'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="timestamp"/>
                <field name="order_ref"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="product_uom_id"/>
                <field name="reason_id"/>
                <field name="location_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="station"/>
                <field name="cost" sum="Total Cost" widget="monetary"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="waste_log_view_form" model="ir.ui.view">
        <field name="name">waste.log.form</field>
        <field name="model">waste.log</field>
        <field name="arch" type="xml">
            <form string="Waste Log">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            class="btn-secondary"
                            invisible="state != 'draft'"
                            confirm="Are you sure you want to cancel this waste log?"/>
                    <button name="action_draft" type="object" string="Reset to Draft"
                            class="btn-secondary"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Waste Details">
                            <field name="product_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <label for="quantity"/>
                            <div class="o_row">
                                <field name="quantity" readonly="state != 'draft'"/>
                                <field name="product_uom_id" groups="uom.group_uom"/>
                            </div>
                            <field name="total_qty_ordered" invisible="not total_qty_ordered" readonly="1"/>
                            <field name="reason_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="other_reason" invisible="not other_reason or reason_id.name != 'Other'" readonly="state != 'draft'"/>
                            <field name="location_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="cost" widget="monetary"/>
                        </group>
                        <group string="Context">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="station"
                                   readonly="state != 'draft'"/>
                            <field name="timestamp"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Linked Records">
                        <group>
                            <field name="order_ref"/>
                            <field name="pos_order_id"/>
                        </group>
                        <group>
                            <field name="preparation_display_id"/>
                            <field name="stock_move_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Photo &amp; Notes" name="photo_notes">
                            <group>
                                <field name="photo" widget="image"
                                       readonly="state != 'draft'"
                                       class="oe_avatar"/>
                                <field name="photo_filename" invisible="1"/>
                            </group>
                            <group>
                                <field name="notes"
                                       readonly="state != 'draft'"
                                       placeholder="Additional notes about this waste event..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="waste_log_view_search" model="ir.ui.view">
        <field name="name">waste.log.search</field>
        <field name="model">waste.log</field>
        <field name="arch" type="xml">
            <search string="Search Waste Logs">
                <field name="name"/>
                <field name="order_ref"/>
                <field name="product_id"/>
                <field name="reason_id"/>
                <field name="location_id"/>
                <field name="user_id"/>
                <field name="station"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('timestamp', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_yesterday" string="Yesterday"
                        domain="[('timestamp', '&gt;=', (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d')), ('timestamp', '&lt;', (context_today()).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_last_7_days" string="Last 7 Days"
                        domain="[('timestamp', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_last_30_days" string="Last 30 Days"
                        domain="[('timestamp', '&gt;=', (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="groupby_product" string="Product"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="groupby_reason" string="Reason"
                            context="{'group_by': 'reason_id'}"/>
                    <filter name="groupby_location" string="Location"
                            context="{'group_by': 'location_id'}"/>
                    <filter name="groupby_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="groupby_station" string="Station"
                            context="{'group_by': 'station'}"/>
                    <filter name="groupby_date" string="Date"
                            context="{'group_by': 'timestamp:day'}"/>
                    <filter name="groupby_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="waste_log_view_kanban" model="ir.ui.view">
        <field name="name">waste.log.kanban</field>
        <field name="model">waste.log</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <field name="name" class="fw-bold"/>
                            <field name="state" widget="label_selection"
                                   options="{'classes': {'draft': 'warning', 'confirmed': 'success', 'cancelled': 'danger'}}"/>
                        </div>
                        <div class="mt-1">
                            <field name="product_id" class="fw-semibold"/>
                        </div>
                        <div class="text-muted small">
                            <span><field name="quantity"/> <field name="product_uom_id"/></span>
                            <span class="float-end"><field name="reason_id"/></span>
                        </div>
                        <div class="text-muted small mt-1">
                            <i class="fa fa-user me-1" title="User"/><field name="user_id"/>
                            <span class="float-end"><field name="timestamp" widget="date"/></span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="waste_log_view_pivot" model="ir.ui.view">
        <field name="name">waste.log.pivot</field>
        <field name="model">waste.log</field>
        <field name="arch" type="xml">
            <pivot string="Waste Analysis">
                <field name="timestamp" type="row" interval="day"/>
                <field name="product_id" type="row"/>
                <field name="reason_id" type="col"/>
                <field name="quantity" type="measure"/>
                <field name="cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="waste_log_view_graph" model="ir.ui.view">
        <field name="name">waste.log.graph</field>
        <field name="model">waste.log</field>
        <field name="arch" type="xml">
            <graph string="Waste Analysis" type="bar" stacked="True">
                <field name="timestamp" interval="day" type="row"/>
                <field name="reason_id" type="col"/>
                <field name="quantity" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action -->
    <record id="action_waste_log" model="ir.actions.act_window">
        <field name="name">Waste Logs</field>
        <field name="res_model">waste.log</field>
        <field name="view_mode">list,kanban,form,pivot,graph</field>
        <field name="search_view_id" ref="waste_log_view_search"/>
        <field name="context">{'search_default_filter_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No waste logs yet
            </p>
            <p>
                Waste logs are created from the Kitchen Display Screen when kitchen staff
                records wasted items.
            </p>
        </field>
    </record>

</odoo>
