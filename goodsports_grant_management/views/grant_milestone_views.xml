<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_grant_milestone_list" model="ir.ui.view">
        <field name="name">grant.milestone.list</field>
        <field name="model">grant.milestone</field>
        <field name="arch" type="xml">
            <list string="Milestones"
                  decoration-danger="is_overdue == True"
                  decoration-success="state == 'done'">
                <field name="grant_id"/>
                <field name="name"/>
                <field name="milestone_type"/>
                <field name="due_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'in_progress'"
                       decoration-danger="is_overdue"/>
                <field name="target_quantity"/>
                <field name="actual_quantity"/>
                <field name="unit_of_measure"/>
                <field name="achievement_pct" widget="progressbar"/>
                <field name="assigned_to_id"/>
                <field name="is_overdue" column_invisible="1"/>
                <button name="action_start" type="object" string="Start"
                        invisible="state != 'pending'" icon="fa-play"/>
                <button name="action_complete" type="object" string="Complete"
                        invisible="state == 'done'" icon="fa-check"/>
            </list>
        </field>
    </record>

    <record id="view_grant_milestone_form" model="ir.ui.view">
        <field name="name">grant.milestone.form</field>
        <field name="model">grant.milestone</field>
        <field name="arch" type="xml">
            <form string="Milestone / Deliverable">
                <header>
                    <button name="action_start" type="object" string="Start"
                            class="btn-primary" invisible="state != 'pending'"/>
                    <button name="action_complete" type="object" string="Mark Complete"
                            class="btn-success" invisible="state in ('done','cancelled')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,in_progress,done"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" text="Overdue" bg_color="text-bg-danger"
                            invisible="not is_overdue"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Milestone or Deliverable Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="grant_id"/>
                            <field name="milestone_type"/>
                            <field name="assigned_to_id"/>
                            <field name="verified_by_id"/>
                        </group>
                        <group>
                            <field name="due_date"/>
                            <field name="completion_date"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="budget_allocated"/>
                            <field name="linked_payment_id"/>
                        </group>
                    </group>
                    <group string="Quantitative Targets">
                        <group>
                            <field name="target_quantity"/>
                            <field name="actual_quantity"/>
                            <field name="unit_of_measure"/>
                        </group>
                        <group>
                            <field name="achievement_pct" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Describe the deliverable and success criteria..."/>
                        </page>
                        <page string="Evidence">
                            <field name="evidence" placeholder="Document how this milestone was achieved..."/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                    <field name="is_overdue" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_grant_milestone" model="ir.actions.act_window">
        <field name="name">Milestones</field>
        <field name="res_model">grant.milestone</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'not in', ['done', 'cancelled'])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No active milestones!</p>
        </field>
    </record>

</odoo>
